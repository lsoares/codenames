{
  "name": "codenames-pictures",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "lsof -ti:5173 -ti:9000 | xargs -I{} kill -9 {} 2>/dev/null; true",
    "dev": "concurrently -k -n vite,broker -c cyan,magenta \"vite --open\" \"npm:broker\"",
    "broker": "peerjs --port 9000 --key peerjs --path /",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "playwright test"
  },
  "dependencies": {
    "peerjs": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^10.0.3",
    "peer": "^1.0.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
